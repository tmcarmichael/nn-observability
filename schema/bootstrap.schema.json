{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tmcarmichael/nn-observability/schema/bootstrap.schema.json",
  "title": "Document-level bootstrap CI",
  "description": "Output of scripts/split_bootstrap_gpu.py. Resamples WikiText documents to bound probe-stability CI at the peak layer.",
  "type": "object",
  "required": [
    "model",
    "peak_layer",
    "ex_dim",
    "n_boot",
    "boot_rhos",
    "mean",
    "std",
    "ci_95",
    "design",
    "provenance"
  ],
  "additionalProperties": true,
  "properties": {
    "model": {
      "type": "string",
      "description": "Hugging Face model identifier (org/name)."
    },
    "peak_layer": {
      "type": "integer",
      "minimum": 0,
      "description": "Peak layer index used for the bootstrap."
    },
    "ex_dim": {
      "type": "integer",
      "minimum": 1,
      "description": "Tokens-per-feature-dim ratio for the probe fit (350 ex/dim canonical)."
    },
    "n_boot": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of document-level bootstrap resamples."
    },
    "boot_rhos": {
      "type": "array",
      "items": {"type": "number"},
      "minItems": 1,
      "description": "Per-resample partial Spearman values."
    },
    "mean": {
      "type": "number",
      "description": "Bootstrap mean of partial Spearman."
    },
    "std": {
      "type": "number",
      "minimum": 0,
      "description": "Bootstrap standard deviation of partial Spearman."
    },
    "ci_95": {
      "type": "array",
      "items": {"type": "number"},
      "minItems": 2,
      "maxItems": 2,
      "description": "[low, high] 95% bootstrap CI."
    },
    "design": {
      "type": "object",
      "description": "Resampling design metadata (probe_seed, note, etc.).",
      "additionalProperties": true
    },
    "provenance": {
      "$ref": "#/$defs/provenance",
      "description": "Run-level reproducibility metadata: model SHA, generating script, timestamp, device."
    }
  },
  "$defs": {
    "provenance": {
      "type": "object",
      "required": ["model_revision", "script", "timestamp", "device"],
      "properties": {
        "model_revision": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "script": {"type": "string"},
        "timestamp": {"type": "string", "format": "date-time"},
        "value_source": {"type": "string", "enum": ["runtime", "post_hoc_deterministic"]},
        "device": {"type": "string", "enum": ["cuda", "mps", "cpu"]}
      },
      "additionalProperties": true
    }
  }
}
